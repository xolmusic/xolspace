// Schema XOL Catalog — catalogue de titres du label
// Un titre appartient a un artiste, et PEUT (facultatif) etre rattache a
// un projet. Ecoute uniquement, upload direct MP3 dans R2.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Artist {
  id           String    @id @default(cuid())
  stageName    String
  photoKey     String?
  country      String?
  bio          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  tracks       Track[]
  shareLinks   ShareLink[]
  epk          Epk?

  @@index([stageName])
}

enum ProjectType {
  SINGLE
  EP
  ALBUM
}

enum ReleaseStatus {
  UNRELEASED
  SCHEDULED
  RELEASED
}

model Project {
  id           String        @id @default(cuid())
  title        String
  type         ProjectType   @default(SINGLE)
  status       ReleaseStatus @default(UNRELEASED)
  coverKey     String?
  releaseDate  DateTime?
  genre        String?
  upc          String?
  catalogRef   String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId     String

  tracks       Track[]
  shareLinks   ShareLink[]

  @@index([artistId])
}

// Un titre. Toujours rattache a un artiste ; le projet est facultatif.
model Track {
  id             String    @id @default(cuid())
  title          String
  position       Int       @default(0)      // ordre dans le projet (si projet)
  genre          String?                    // style du titre
  isrc           String?
  bpm            Int?
  songKey        String?
  durationSec    Int?
  audioKey       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String

  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId      String?

  shareLinks     ShareLink[]

  @@index([artistId])
  @@index([projectId])
}

enum ShareTargetType {
  PROJECT
  TRACK
  ARTIST
  EPK
}

model ShareLink {
  id             String          @id @default(cuid())
  token          String          @unique
  targetType     ShareTargetType
  label          String?

  passwordHash   String?
  expiresAt      DateTime?
  revoked        Boolean         @default(false)

  viewCount      Int             @default(0)
  createdAt      DateTime        @default(now())

  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String?
  track          Track?          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId        String?
  artist         Artist?         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String?
  epk            Epk?            @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId          String?

  events         PlayEvent[]

  @@index([token])
}

model PlayEvent {
  id           String    @id @default(cuid())
  shareLink    ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shareLinkId  String
  trackId      String?
  kind         String    @default("play")
  country      String?
  createdAt    DateTime  @default(now())

  @@index([shareLinkId])
}

// --- Presskit / EPK d'un artiste (relation 1-1) ---
model Epk {
  id             String    @id @default(cuid())
  bio            String?               // bio dediee EPK (longue)
  tagline        String?               // accroche courte
  // reseaux et contacts
  facebook       String?
  tiktok         String?
  instagram      String?
  spotify        String?
  appleMusic     String?
  bookingEmail   String?
  published      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String    @unique

  photos         EpkPhoto[]
  videos         EpkVideo[]
  items          EpkItem[]
  shareLinks     ShareLink[]
}

model EpkPhoto {
  id        String   @id @default(cuid())
  imageKey  String                 // cle R2
  position  Int      @default(0)
  epk       Epk      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId     String

  @@index([epkId])
}

model EpkVideo {
  id        String   @id @default(cuid())
  url       String                 // lien YouTube
  title     String?
  position  Int      @default(0)
  epk       Epk      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId     String

  @@index([epkId])
}

// Element de musique selectionne pour l'EPK : soit un titre, soit un projet.
model EpkItem {
  id         String   @id @default(cuid())
  position   Int      @default(0)
  trackId    String?
  projectId  String?
  epk        Epk      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId      String

  @@index([epkId])
}

// --- CRM : base de contacts professionnels ---
enum ContactType {
  JOURNALIST
  RADIO
  BLOG
  PLAYLIST_CURATOR
  MANAGER
  BOOKER
  LABEL
  STUDIO
  INFLUENCER
}

model Contact {
  id            String       @id @default(cuid())
  name          String
  type          ContactType
  organization  String?
  email         String?
  phone         String?
  country       String?
  socials       String?               // liens libres (instagram, site...)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  interactions  Interaction[]

  @@index([type])
  @@index([name])
}

enum InteractionStatus {
  TO_CONTACT     // A contacter
  SENT           // Envoye
  FOLLOWED_UP    // Relance
  REPLIED        // Repondu
  POSITIVE       // Positif
  NEGATIVE       // Negatif
  NO_REPLY       // Sans reponse
}

// Chaque prise de contact avec un contact : lien envoye, dates, statut.
model Interaction {
  id            String            @id @default(cuid())
  status        InteractionStatus @default(TO_CONTACT)
  subject       String?                     // ex: "Sortie EP Kallya"
  // lien envoye : soit un lien de partage interne (token), soit une URL libre
  shareToken    String?                     // token d'un ShareLink de l'outil
  externalUrl   String?                     // ou une URL libre
  sentAt        DateTime?                   // date d'envoi
  repliedAt     DateTime?                   // date de reponse
  followUpAt    DateTime?                   // date de relance prevue
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  contact       Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId     String

  @@index([contactId])
  @@index([status])
  @@index([followUpAt])
}
