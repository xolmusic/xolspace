// Schema XOL Catalog — catalogue de titres du label
// Un titre appartient a un artiste, et PEUT (facultatif) etre rattache a
// un projet. Ecoute uniquement, upload direct MP3 dans R2.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Artist {
  id           String    @id @default(cuid())
  stageName    String
  photoKey     String?
  country      String?
  bio          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  tracks       Track[]
  shareLinks   ShareLink[]

  @@index([stageName])
}

enum ProjectType {
  SINGLE
  EP
  ALBUM
}

enum ReleaseStatus {
  UNRELEASED
  SCHEDULED
  RELEASED
}

model Project {
  id           String        @id @default(cuid())
  title        String
  type         ProjectType   @default(SINGLE)
  status       ReleaseStatus @default(UNRELEASED)
  coverKey     String?
  releaseDate  DateTime?
  genre        String?
  upc          String?
  catalogRef   String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId     String

  tracks       Track[]
  shareLinks   ShareLink[]

  @@index([artistId])
}

// Un titre. Toujours rattache a un artiste ; le projet est facultatif.
model Track {
  id             String    @id @default(cuid())
  title          String
  position       Int       @default(0)      // ordre dans le projet (si projet)
  genre          String?                    // style du titre
  isrc           String?
  bpm            Int?
  songKey        String?
  durationSec    Int?
  audioKey       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String

  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId      String?

  shareLinks     ShareLink[]

  @@index([artistId])
  @@index([projectId])
}

enum ShareTargetType {
  PROJECT
  TRACK
  ARTIST
}

model ShareLink {
  id             String          @id @default(cuid())
  token          String          @unique
  targetType     ShareTargetType
  label          String?

  passwordHash   String?
  expiresAt      DateTime?
  revoked        Boolean         @default(false)

  viewCount      Int             @default(0)
  createdAt      DateTime        @default(now())

  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String?
  track          Track?          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId        String?
  artist         Artist?         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String?

  events         PlayEvent[]

  @@index([token])
}

model PlayEvent {
  id           String    @id @default(cuid())
  shareLink    ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shareLinkId  String
  trackId      String?
  kind         String    @default("play")
  country      String?
  createdAt    DateTime  @default(now())

  @@index([shareLinkId])
}
