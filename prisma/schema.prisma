// Schema XOL Catalog — catalogue de titres du label
// Un titre appartient a un artiste, et PEUT (facultatif) etre rattache a
// un projet. Ecoute uniquement, upload direct MP3 dans R2.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(SUPER_ADMIN)
  createdAt    DateTime @default(now())
}

enum Role {
  SUPER_ADMIN   // acces total, y compris la gestion des utilisateurs
  USER          // acces a tout sauf la gestion des utilisateurs
}

model Artist {
  id           String    @id @default(cuid())
  stageName    String
  photoKey     String?
  country      String?
  bio          String?
  relationType RelationType @default(LABEL)   // artiste du label ou externe
  mandateNotes String?                        // cadre du mandat (externes)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  tracks       Track[]
  shareLinks   ShareLink[]
  epk          Epk?
  campaigns    Campaign[]
  transactions Transaction[]

  @@index([stageName])
  @@index([relationType])
}

enum RelationType {
  LABEL      // artiste signe / du label
  EXTERNAL   // artiste externe ayant mandate le label
}

enum ProjectType {
  SINGLE
  EP
  ALBUM
}

enum ReleaseStatus {
  UNRELEASED
  SCHEDULED
  RELEASED
}

model Project {
  id           String        @id @default(cuid())
  title        String
  type         ProjectType   @default(SINGLE)
  status       ReleaseStatus @default(UNRELEASED)
  coverKey     String?
  releaseDate  DateTime?
  genre        String?
  upc          String?
  catalogRef   String?
  notes        String?
  budget       Int?          // budget prevu, en FCFA entiers
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId     String

  tracks       Track[]
  shareLinks   ShareLink[]
  campaigns    Campaign[]
  transactions Transaction[]

  @@index([artistId])
}

// Un titre. Toujours rattache a un artiste ; le projet est facultatif.
model Track {
  id             String    @id @default(cuid())
  title          String
  position       Int       @default(0)      // ordre dans le projet (si projet)
  genre          String?                    // style du titre
  isrc           String?
  bpm            Int?
  songKey        String?
  durationSec    Int?
  audioKey       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String

  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId      String?

  shareLinks     ShareLink[]

  @@index([artistId])
  @@index([projectId])
}

enum ShareTargetType {
  PROJECT
  TRACK
  ARTIST
  EPK
}

model ShareLink {
  id             String          @id @default(cuid())
  token          String          @unique
  targetType     ShareTargetType
  label          String?

  passwordHash   String?
  expiresAt      DateTime?
  revoked        Boolean         @default(false)

  viewCount      Int             @default(0)
  createdAt      DateTime        @default(now())

  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String?
  track          Track?          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId        String?
  artist         Artist?         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String?
  epk            Epk?            @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId          String?

  events         PlayEvent[]

  @@index([token])
}

model PlayEvent {
  id           String    @id @default(cuid())
  shareLink    ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shareLinkId  String
  trackId      String?
  kind         String    @default("play")
  country      String?
  createdAt    DateTime  @default(now())

  @@index([shareLinkId])
}

// --- Presskit / EPK d'un artiste (relation 1-1) ---
model Epk {
  id             String    @id @default(cuid())
  bio            String?               // bio dediee EPK (longue)
  tagline        String?               // accroche courte
  // reseaux et contacts
  facebook       String?
  tiktok         String?
  instagram      String?
  spotify        String?
  appleMusic     String?
  bookingEmail   String?
  published      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String    @unique

  photos         EpkPhoto[]
  videos         EpkVideo[]
  items          EpkItem[]
  shareLinks     ShareLink[]
}

model EpkPhoto {
  id        String   @id @default(cuid())
  imageKey  String                 // cle R2
  position  Int      @default(0)
  epk       Epk      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId     String

  @@index([epkId])
}

model EpkVideo {
  id        String   @id @default(cuid())
  url       String                 // lien YouTube
  title     String?
  position  Int      @default(0)
  epk       Epk      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId     String

  @@index([epkId])
}

// Element de musique selectionne pour l'EPK : soit un titre, soit un projet.
model EpkItem {
  id         String   @id @default(cuid())
  position   Int      @default(0)
  trackId    String?
  projectId  String?
  epk        Epk      @relation(fields: [epkId], references: [id], onDelete: Cascade)
  epkId      String

  @@index([epkId])
}

// --- CRM : base de contacts professionnels ---
enum ContactType {
  JOURNALIST
  RADIO
  BLOG
  PLAYLIST_CURATOR
  MANAGER
  BOOKER
  LABEL
  STUDIO
  INFLUENCER
  TV
}

model Contact {
  id            String       @id @default(cuid())
  name          String
  type          ContactType
  organization  String?               // media / structure
  email         String?
  phone         String?
  country       String?
  city          String?
  language      String?               // langue de travail
  genres        String?               // genres couverts (liste libre, separes par des virgules)
  followedArtists String?             // artistes suivis (texte libre)
  socials       String?               // liens libres (instagram, site...)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  interactions  Interaction[]
  campaignRecipients CampaignRecipient[]

  @@index([type])
  @@index([name])
  @@index([country])
}

enum InteractionStatus {
  TO_CONTACT     // A contacter
  SENT           // Envoye
  FOLLOWED_UP    // Relance
  REPLIED        // Repondu
  POSITIVE       // Positif
  NEGATIVE       // Negatif
  NO_REPLY       // Sans reponse
}

// Chaque prise de contact avec un contact : lien envoye, dates, statut.
model Interaction {
  id            String            @id @default(cuid())
  status        InteractionStatus @default(TO_CONTACT)
  subject       String?                     // ex: "Sortie EP Kallya"
  // lien envoye : soit un lien de partage interne (token), soit une URL libre
  shareToken    String?                     // token d'un ShareLink de l'outil
  externalUrl   String?                     // ou une URL libre
  sentAt        DateTime?                   // date d'envoi
  repliedAt     DateTime?                   // date de reponse
  followUpAt    DateTime?                   // date de relance prevue
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  contact       Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId     String

  @@index([contactId])
  @@index([status])
  @@index([followUpAt])
}

// --- Campagnes media (promo d'une sortie) ---
enum CampaignStatus {
  DRAFT       // brouillon
  ACTIVE      // en cours
  CLOSED      // terminee
}

model Campaign {
  id             String    @id @default(cuid())
  name           String
  status         CampaignStatus @default(DRAFT)
  pitch          String?               // pitch du morceau / angle
  shareToken     String?               // lien d'ecoute privee associe (token)
  emailSubject   String?
  emailBody      String?               // modele avec variables {{prenom}} etc.
  signature      String?
  fromName       String?               // nom d'expediteur affiche
  followUp1Days  Int       @default(5)  // 1re relance : J+5
  followUp2Days  Int       @default(15) // 2e relance : J+15
  followUp1Body  String?               // message de la 1re relance
  followUp2Body  String?               // message de la 2e relance
  autoFollowUp   Boolean   @default(false) // relances automatiques activees
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId      String?

  recipients     CampaignRecipient[]

  @@index([artistId])
  @@index([projectId])
}

enum RecipientStatus {
  TO_SEND     // a envoyer
  SENT        // envoye
  REPLIED     // a repondu
  PUBLISHED   // a publie
  DECLINED    // pas interesse
  NO_REPLY    // sans reponse
}

model CampaignRecipient {
  id           String   @id @default(cuid())
  status       RecipientStatus @default(TO_SEND)
  sentAt       DateTime?
  repliedAt    DateTime?
  publishedAt  DateTime?
  resultUrl    String?               // lien de l'article / playlist / passage
  notes        String?

  // Envoi & tracking
  trackId          String   @unique @default(cuid()) // identifiant de suivi (URL de clic)
  clickCount       Int      @default(0)               // clics sur le lien d'ecoute
  firstClickAt     DateTime?
  unsubscribed     Boolean  @default(false)           // desinscription
  lastError        String?                            // erreur d'envoi eventuelle

  // Relances programmees
  followUp1SentAt  DateTime?
  followUp2SentAt  DateTime?
  followUp1DueAt   DateTime?
  followUp2DueAt   DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId   String
  contact      Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId    String

  @@unique([campaignId, contactId])
  @@index([campaignId])
  @@index([contactId])
}

// --- Finances : journal unique (depenses + entrees) ---
enum TxType {
  EXPENSE   // depense
  INCOME    // entree
}

// Montants : entiers en FCFA. Le franc CFA n'a pas de decimales, le
// stockage en entier est donc exact (aucun arrondi possible).
model Transaction {
  id          String   @id @default(cuid())
  type        TxType
  date        DateTime
  amount      Int                   // FCFA, entier positif
  category    String                // libelle de categorie (voir TxCategory)
  label       String?               // description ("Studio", "Clip"...)
  counterparty String?              // fournisseur ou payeur
  receiptKey  String?               // justificatif (facture/recu) dans R2
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Rattachement : artiste et/ou projet, ou rien (frais generaux du label).
  artist      Artist?  @relation(fields: [artistId], references: [id], onDelete: SetNull)
  artistId    String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?

  @@index([type])
  @@index([date])
  @@index([artistId])
  @@index([projectId])
  @@index([category])
}

// Categories modifiables depuis l'interface (pas figees dans le code).
model TxCategory {
  id       String @id @default(cuid())
  name     String
  type     TxType
  position Int    @default(0)

  @@unique([name, type])
  @@index([type])
}
