// Schema XOL Catalog — catalogue d'ecoute du label
// PostgreSQL (Neon). Modele simplifie : un seul fichier audio (MP3) par
// titre ou demo, uploade directement dans R2 depuis le navigateur.
// Ecoute uniquement — pas de telechargement.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
}

model Artist {
  id           String    @id @default(cuid())
  stageName    String
  photoKey     String?
  country      String?
  bio          String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  projects     Project[]
  tracks       Track[]
  demos        Demo[]
  shareLinks   ShareLink[]

  @@index([stageName])
}

enum ProjectType {
  SINGLE
  EP
  ALBUM
}

enum ReleaseStatus {
  UNRELEASED
  SCHEDULED
  RELEASED
}

model Project {
  id           String        @id @default(cuid())
  title        String
  type         ProjectType   @default(SINGLE)
  status       ReleaseStatus @default(UNRELEASED)
  coverKey     String?
  releaseDate  DateTime?
  genre        String?
  upc          String?
  catalogRef   String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  artist       Artist        @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId     String

  tracks       Track[]
  shareLinks   ShareLink[]

  @@index([artistId])
}

model Track {
  id             String    @id @default(cuid())
  title          String
  position       Int       @default(1)
  isrc           String?
  bpm            Int?
  songKey        String?
  durationSec    Int?
  audioKey       String                    // cle R2 du MP3 (ecoute)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String
  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String

  shareLinks     ShareLink[]

  @@index([projectId])
  @@index([artistId])
}

model Demo {
  id             String    @id @default(cuid())
  title          String
  audioKey       String                    // cle R2 du MP3
  durationSec    Int?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  artist         Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String

  shareLinks     ShareLink[]

  @@index([artistId])
}

enum ShareTargetType {
  PROJECT
  TRACK
  DEMO
  ARTIST
}

// Liens de partage publics : ecoute seule, revocable, expiration et
// mot de passe optionnels. Plus de telechargement.
model ShareLink {
  id             String          @id @default(cuid())
  token          String          @unique
  targetType     ShareTargetType
  label          String?

  passwordHash   String?
  expiresAt      DateTime?
  revoked        Boolean         @default(false)

  viewCount      Int             @default(0)
  createdAt      DateTime        @default(now())

  project        Project?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId      String?
  track          Track?          @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId        String?
  demo           Demo?           @relation(fields: [demoId], references: [id], onDelete: Cascade)
  demoId         String?
  artist         Artist?         @relation(fields: [artistId], references: [id], onDelete: Cascade)
  artistId       String?

  events         PlayEvent[]

  @@index([token])
}

model PlayEvent {
  id           String    @id @default(cuid())
  shareLink    ShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shareLinkId  String
  trackId      String?
  kind         String    @default("play")
  country      String?
  createdAt    DateTime  @default(now())

  @@index([shareLinkId])
}
